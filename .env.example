# Copie para .env e preencha com seus valores.
# Não commite o .env (já está no .gitignore).

# Supabase — use a connection string do Pooler (porta 6543) para serverless/cloud.
# Se a senha tiver @, use %40 no lugar.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require

# Opcional
MAX_WORKERS=8
CHUNK_SIZE=1000
# Railway Pro: tamanho máximo por arquivo em MB (default 2048 = 2 GB)
# MAX_UPLOAD_PART_MB=2048

# Opcional (Supabase REST/API)
SUPABASE_URL=https://SEU_PROJECT.supabase.co
SUPABASE_KEY=sua_anon_key

# ── GCP (Storage + BigQuery) — quando preenchido, a UI usa upload direto para GCS e load no BigQuery ──
# Não commite o JSON da service account (use variáveis de ambiente no Railway).
# GCP_PROJECT_ID=seu-projeto-id
# GCP_BUCKET=nome-do-bucket
# GCP_DATASET=etl
# GCP_CREDENTIALS_JSON={"type":"service_account",...}   ← cole o conteúdo do arquivo .json (uma linha)
