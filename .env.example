# Copie para .env e preencha com seus valores.
# Não commite o .env (já está no .gitignore).

# Supabase — use a connection string do Pooler (porta 6543) para serverless/cloud.
# Se a senha tiver @, use %40 no lugar.
#DATABASE_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require

# Opcional
MAX_WORKERS=8
CHUNK_SIZE=1000
# Railway Pro: tamanho máximo por arquivo em MB (default 2048 = 2 GB)
# MAX_UPLOAD_PART_MB=2048



# ── GCP (Storage + BigQuery) — obrigatório para rodar o app ──
GCP_PROJECT_ID=springboot-demo-484902
GCP_BUCKET=el-lucas
GCP_DATASET=dataset_lucas

# Opção 1 — LOCAL: use o nome do arquivo .json (deixe o arquivo na pasta do projeto)
GOOGLE_APPLICATION_CREDENTIALS=springboot-demo-484902-6d1ccdd455a6.json

# Opção 2 — RAILWAY: cole o conteúdo do JSON numa linha (não use Opção 1 no Railway)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"springboot-demo-484902",...}

# Opcional
# CHUNK_SIZE=1000
# ROWS_PER_BATCH=50000
# GCP_LOCATION=US
